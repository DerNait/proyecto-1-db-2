@inherits LayoutComponentBase
@inject AppState State
@inject NavigationManager Nav
@implements IDisposable

<div class="layout-root">
    @if (State.IsAuthenticated)
    {
        <nav class="sidebar">
            <div class="sidebar-logo">
                <div class="sidebar-logo-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 11l19-9-9 19-2-8-8-2z"/>
                    </svg>
                </div>
                <div>
                    <div class="sidebar-logo-text">RestaurantOS</div>
                    <div class="sidebar-logo-sub">Sistema de Pedidos</div>
                </div>
            </div>

            <div class="sidebar-nav">
                <div class="nav-section-label">Principal</div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="9" x="3" y="3"/><rect width="7" height="5" x="14" y="3"/><rect width="7" height="9" x="14" y="12"/><rect width="7" height="5" x="3" y="16"/></svg>
                        Dashboard
                    </NavLink>
                </div>

                <div class="nav-section-label">Gestion</div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="restaurantes">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
                        Restaurantes
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="articulos">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        Articulos
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="pedidos">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                        Pedidos
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="resenas">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        Resenas
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="usuarios">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        Usuarios
                    </NavLink>
                </div>

                <div class="nav-section-label">Datos</div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="archivos">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                        Archivos GridFS
                    </NavLink>
                </div>
                <div class="nav-item">
                    <NavLink class="nav-link" href="reportes">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                        Reportes
                    </NavLink>
                </div>
            </div>

            <div class="sidebar-footer">
                <div class="user-pill">
                    <div class="user-avatar">@Initials</div>
                    <div class="user-info">
                        <div class="user-name">@State.Nombre</div>
                        <div class="user-role">@State.Email</div>
                    </div>
                    <button class="btn btn-ghost btn-sm" @onclick="Logout" title="Cerrar sesion" style="padding:4px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </button>
                </div>
            </div>
        </nav>

        <div class="main-wrapper">
            <article class="page-content">
                @Body
            </article>
        </div>
    }
    else
    {
        @Body
    }
</div>

@code {
    private string Initials => string.IsNullOrEmpty(State.Nombre) ? "?" :
        string.Concat(State.Nombre.Split(' ').Take(2).Select(w => w[0])).ToUpper();

    protected override void OnInitialized()
    {
        State.OnChange += StateHasChanged;
    }

    private void Logout()
    {
        State.Logout();
        Nav.NavigateTo("/");
    }

    public void Dispose()
    {
        State.OnChange -= StateHasChanged;
    }
}
