@page "/"
@inject ApiService Api
@inject AppState State
@inject NavigationManager Nav
@implements IDisposable

@if (!State.IsAuthenticated)
{
    <div class="login-page">
        <div class="login-card">
            <div class="login-brand">
                <div class="login-brand-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
                </div>
                <div class="login-brand-text">
                    <h1>RestaurantOS</h1>
                    <p>Sistema de Gestion de Pedidos</p>
                </div>
            </div>

            <div class="login-tabs">
                <button class="login-tab @(tab=="login"?"active":"")" @onclick='()=>tab="login"'>Iniciar Sesion</button>
                <button class="login-tab @(tab=="registro"?"active":"")" @onclick='()=>tab="registro"'>Registrarse</button>
            </div>

            @if (!string.IsNullOrEmpty(mensaje))
            {
                <div class="alert @(isError?"alert-error":"alert-success")">@mensaje</div>
            }

            @if (tab == "login")
            {
                <div class="form-group">
                    <label class="form-label">Correo electronico</label>
                    <input @bind="email" class="form-control" placeholder="usuario@ejemplo.com" type="email"/>
                </div>
                <div class="form-group">
                    <label class="form-label">Contrasena</label>
                    <input @bind="password" class="form-control" type="password" placeholder="Contrasena"/>
                </div>
                <button class="btn btn-primary w-100" @onclick="HacerLogin" disabled="@cargando" style="width:100%;">
                    @if (cargando) { <div class="spinner" style="width:16px;height:16px;"></div> }
                    Ingresar al Sistema
                </button>
            }
            else
            {
                <div class="form-group">
                    <label class="form-label">Nombre completo</label>
                    <input @bind="nombre" class="form-control" placeholder="Tu nombre"/>
                </div>
                <div class="form-group">
                    <label class="form-label">Correo electronico</label>
                    <input @bind="email" class="form-control" placeholder="usuario@ejemplo.com" type="email"/>
                </div>
                <div class="form-group">
                    <label class="form-label">Contrasena</label>
                    <input @bind="password" class="form-control" type="password" placeholder="Minimo 6 caracteres"/>
                </div>
                <button class="btn btn-primary" @onclick="HacerRegistro" disabled="@cargando" style="width:100%;">
                    @if (cargando) { <div class="spinner" style="width:16px;height:16px;"></div> }
                    Crear cuenta
                </button>
            }
        </div>
    </div>
}
else
{
    <PageTitle>Dashboard - RestaurantOS</PageTitle>
    <div class="page-header">
        <div class="page-header-row">
            <div>
                <h1>Bienvenido, @State.Nombre</h1>
                <p>Vista general del sistema de pedidos</p>
            </div>
        </div>
    </div>

    @if (cargandoDash)
    {
        <div class="loading-indicator"><div class="spinner"></div> Cargando datos...</div>
    }
    else
    {
        <div class="stats-grid">
            <div class="stat-card primary">
                <div class="stat-icon primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>
                </div>
                <div class="stat-value">@totalRestaurantes</div>
                <div class="stat-label">Restaurantes activos</div>
            </div>
            <div class="stat-card success">
                <div class="stat-icon success">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/></svg>
                </div>
                <div class="stat-value">@totalPedidos</div>
                <div class="stat-label">Pedidos totales</div>
            </div>
            <div class="stat-card warning">
                <div class="stat-icon warning">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                </div>
                <div class="stat-value">@totalArticulos</div>
                <div class="stat-label">Articulos en menu</div>
            </div>
            <div class="stat-card danger">
                <div class="stat-icon danger">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </div>
                <div class="stat-value">@totalResenas</div>
                <div class="stat-label">Resenas totales</div>
            </div>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Top Restaurantes por Rating</div>
                </div>
                <div class="card-body">
                    @if (topRestaurantes.Any())
                    {
                        <div class="bar-chart">
                            @foreach (var r in topRestaurantes)
                            {
                                var pct = (r.Promedio / 5.0) * 100;
                                <div class="bar-item">
                                    <div class="bar-label" title="@r.Nombre">@r.Nombre</div>
                                    <div class="bar-track"><div class="bar-fill" style="width:@pct.ToString("0")%"></div></div>
                                    <div class="bar-value">@r.Promedio.ToString("0.0")</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state" style="padding:24px">
                            <p>Sin datos de restaurantes todavia</p>
                        </div>
                    }
                </div>
            </div>
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Platillos Mas Vendidos</div>
                </div>
                <div class="card-body">
                    @if (platillos.Any())
                    {
                        var maxVal = platillos.Max(p => p.CantidadVendida);
                        <div class="bar-chart">
                            @foreach (var p in platillos)
                            {
                                var pct = maxVal > 0 ? ((double)p.CantidadVendida / maxVal) * 100 : 0;
                                <div class="bar-item">
                                    <div class="bar-label" title="@p.Nombre">@p.Nombre</div>
                                    <div class="bar-track"><div class="bar-fill" style="width:@pct.ToString("0")%;background:linear-gradient(90deg,#10b981,#059669)"></div></div>
                                    <div class="bar-value">@p.CantidadVendida</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state" style="padding:24px">
                            <p>Sin datos de ventas todavia</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

@code {
    private string tab = "login";
    private string email = "", password = "", nombre = "", mensaje = "";
    private bool isError, cargando, cargandoDash = true;

    private int totalRestaurantes, totalPedidos, totalArticulos, totalResenas;

    private record TopR(string Nombre, double Promedio, int TotalResenas);
    private record PlatilloR(string Nombre, int CantidadVendida);

    private List<TopR> topRestaurantes = new();
    private List<PlatilloR> platillos = new();

    protected override async Task OnInitializedAsync()
    {
        State.OnChange += StateHasChanged;
        if (State.IsAuthenticated)
            await CargarDashboard();
    }

    private async Task CargarDashboard()
    {
        cargandoDash = true;
        try
        {
            var restos = await Api.GetRestaurantesAsync(activo: true, limit: 1);
            totalRestaurantes = restos?.GetProperty("total").GetInt32() ?? 0;

            var peds = await Api.GetPedidosAsync(limit: 1);
            totalPedidos = peds?.GetProperty("total").GetInt32() ?? 0;

            var arts = await Api.GetArticulosAsync(limit: 1);
            totalArticulos = arts?.GetProperty("total").GetInt32() ?? 0;

            var resenas = await Api.GetResenasAsync(limit: 1);
            totalResenas = resenas?.GetProperty("total").GetInt32() ?? 0;

            var top = await Api.GetTopRestaurantesAsync(5);
            if (top.HasValue)
                topRestaurantes = top.Value.EnumerateArray()
                    .Select(r => new TopR(
                        r.TryGetProperty("Nombre", out var n) ? n.GetString()! : "?",
                        r.TryGetProperty("Promedio", out var p) ? p.GetDouble() : 0,
                        r.TryGetProperty("TotalResenas", out var tr) ? tr.GetInt32() : 0))
                    .ToList();

            var pl = await Api.GetPlatillosMasVendidosAsync(5);
            if (pl.HasValue)
                platillos = pl.Value.EnumerateArray()
                    .Select(p => new PlatilloR(
                        p.TryGetProperty("Nombre", out var n) ? n.GetString()! : "?",
                        p.TryGetProperty("CantidadVendida", out var c) ? c.GetInt32() : 0))
                    .ToList();
        }
        finally { cargandoDash = false; }
    }

    private async Task HacerLogin()
    {
        cargando = true; mensaje = "";
        var token = await Api.LoginAsync(email, password);
        if (token != null)
        {
            State.Login(token);
            await CargarDashboard();
        }
        else { mensaje = "Credenciales incorrectas. Intenta de nuevo."; isError = true; }
        cargando = false;
    }

    private async Task HacerRegistro()
    {
        cargando = true; mensaje = "";
        var ok = await Api.RegistrarAsync(new { nombre, email, password, roles = new[] { "cliente" }, direcciones = Array.Empty<object>() });
        if (ok) { mensaje = "Cuenta creada. Ahora inicia sesion."; isError = false; tab = "login"; }
        else { mensaje = "Error al registrarse. El correo puede ya existir."; isError = true; }
        cargando = false;
    }

    public void Dispose() => State.OnChange -= StateHasChanged;
}