@page "/pedidos"
@inject ApiService Api

<PageTitle>Pedidos - RestaurantOS</PageTitle>

<div class="page-header">
    <div class="page-header-row">
        <div><h1>Pedidos</h1><p>Gestion de pedidos con transacciones ACID</p></div>
        <button class="btn btn-primary" @onclick="()=>crearModal=true">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nuevo Pedido
        </button>
    </div>
</div>

<div class="filter-row">
    <select @bind="estadoFiltro" class="form-control" style="width:150px;">
        <option value="">Todos los estados</option>
        <option value="RECIBIDO">Recibido</option>
        <option value="PREPARANDO">Preparando</option>
        <option value="EN_CAMINO">En camino</option>
        <option value="ENTREGADO">Entregado</option>
        <option value="CANCELADO">Cancelado</option>
    </select>
    <select @bind="restFiltro" class="form-control" style="width:200px;">
        <option value="">Restaurante: Todos</option>
        @foreach (var r in restaurantesList) { <option value="@r.Id">@r.Nombre</option> }
    </select>
    <button class="btn btn-secondary" @onclick="Buscar">Filtrar</button>
</div>

@if (!string.IsNullOrEmpty(msgGlobal))
{
    <div class="alert @(isErr?"alert-error":"alert-success")">@msgGlobal</div>
}

<div class="card">
    <div class="card-header"><div class="card-title">@total pedido(s)</div></div>
    @if (cargando)
    {
        <div class="loading-indicator"><div class="spinner"></div>Cargando...</div>
    }
    else if (!pedidos.Any())
    {
        <div class="empty-state"><h3>Sin pedidos</h3></div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead><tr><th>ID</th><th>Cliente</th><th>Restaurante</th><th>Total</th><th>Estado</th><th>Fecha</th><th>Acciones</th></tr></thead>
                <tbody>
                @foreach (var p in pedidos)
                {
                    <tr>
                        <td style="font-family:monospace;font-size:0.75rem;color:var(--text-muted);">@p.Id?.Substring(0,8)...</td>
                        <td style="font-size:0.875rem;">
                            <div>@p.UsuarioNombre</div>
                            <div style="font-size:0.75rem;color:var(--text-muted);">@p.UsuarioEmail</div>
                        </td>
                        <td>@p.RestauranteNombre</td>
                        <td style="font-weight:700;color:var(--accent-success);">Q@p.Total.ToString("0.00")</td>
                        <td>
                            <span class="badge @GetEstadoBadge(p.Estado)">
                                <span class="status-dot @p.Estado.ToLower()" style="margin-right:4px;"></span>
                                @p.Estado
                            </span>
                        </td>
                        <td style="font-size:0.78rem;color:var(--text-muted);">@p.Fecha.ToString("dd/MM/yy HH:mm")</td>
                        <td>
                            @if (p.Estado != "CANCELADO" && p.Estado != "ENTREGADO")
                            {
                                <button class="btn btn-warning btn-sm" @onclick="()=>Cancelar(p.Id!)">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                    Cancelar
                                </button>
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        <div style="padding:16px;">
            <div class="pagination">
                <button class="page-btn" @onclick="()=>CambiarPagina(pagina-1)" disabled="@(pagina==0)">Ant</button>
                <span class="page-info">Pag @(pagina+1)</span>
                <button class="page-btn" @onclick="()=>CambiarPagina(pagina+1)" disabled="@(pedidos.Count<limite)">Sig</button>
            </div>
        </div>
    }
</div>

@if (crearModal)
{
    <div class="modal-overlay">
        <div class="modal modal-lg">
            <div class="modal-header">
                <div class="modal-title">Nuevo Pedido</div>
                <button class="modal-close" @onclick="()=>crearModal=false">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="modal-body">
                @if (!string.IsNullOrEmpty(msgModal))
                {
                    <div class="alert @(modalErr?"alert-error":"alert-success")">@msgModal</div>
                }
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Usuario</label>
                        <select @bind="pUsuId" class="form-control">
                            <option value="">Selecciona un usuario...</option>
                            @foreach (var u in usuariosList) { <option value="@u.Id">@u.Nombre (@u.Email)</option> }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Restaurante</label>
                        <select @bind="pRestId" class="form-control">
                            <option value="">Selecciona un restaurante...</option>
                            @foreach (var r in restaurantesList) { <option value="@r.Id">@r.Nombre</option> }
                        </select>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Latitud entrega</label>
                        <input @bind="pLat" class="form-control" type="number" step="0.0001"/>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Longitud entrega</label>
                        <input @bind="pLon" class="form-control" type="number" step="0.0001"/>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label" style="margin-bottom:8px;">Items del Pedido</label>
                    @foreach (var item in pItems)
                    {
                        <div class="cart-item">
                            <select @bind="item.ArticuloId" class="form-control" style="flex:1;">
                                <option value="">Selecciona articulo...</option>
                                @foreach (var a in articulosList) { <option value="@a.Id">@a.Nombre (Q@a.Precio)</option> }
                            </select>
                            <div class="cart-item-qty">
                                <button class="qty-btn" @onclick="()=>{if(item.Cantidad>1)item.Cantidad--;}">-</button>
                                <span class="qty-num">@item.Cantidad</span>
                                <button class="qty-btn" @onclick="()=>item.Cantidad++">+</button>
                            </div>
                            <button class="btn btn-danger btn-sm" @onclick="()=>pItems.Remove(item)">x</button>
                        </div>
                    }
                    <button class="btn btn-ghost btn-sm" @onclick="()=>pItems.Add(new())">+ Agregar articulo</button>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" @onclick="()=>crearModal=false">Cancelar</button>
                <button class="btn btn-primary" @onclick="CrearPedido" disabled="@guardando">
                    @if (guardando) { <div class="spinner" style="width:14px;height:14px;"></div> }
                    Confirmar Pedido
                </button>
            </div>
        </div>
    </div>
}

@code {
    private class PedidoVm { public string? Id; public string UsuarioNombre=""; public string UsuarioEmail=""; public string RestauranteNombre=""; public double Total; public string Estado=""; public DateTime Fecha; }
    private class ItemInput { public string ArticuloId=""; public int Cantidad=1; }

    private List<PedidoVm> pedidos = new();
    private string estadoFiltro="", restFiltro="", msgGlobal="", msgModal="";
    private int pagina=0, limite=15, total=0;
    private bool cargando, guardando, crearModal, modalErr, isErr;
    private string pUsuId="", pRestId=""; private double pLat, pLon;
    private List<ItemInput> pItems = new() { new() };

    private class DtoSelect { public string Id=""; public string Nombre=""; public string Email=""; public double Precio=0; }
    private List<DtoSelect> restaurantesList = new();
    private List<DtoSelect> usuariosList = new();
    private List<DtoSelect> articulosList = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarFiltrosAsync();
        await CargarAsync();
    }

    private async Task CargarFiltrosAsync()
    {
        var rRest = await Api.GetRestaurantesAsync(skip: 0, limit: 100);
        if (rRest.HasValue) restaurantesList = rRest.Value.GetProperty("items").EnumerateArray()
            .Select(i => new DtoSelect { Id=i.GetProperty("id").GetString()!, Nombre=i.GetProperty("nombre").GetString()! }).ToList();

        var rUsu = await Api.GetUsuariosAsync(skip: 0, limit: 100);
        if (rUsu.HasValue) usuariosList = rUsu.Value.EnumerateArray()
            .Select(i => new DtoSelect { Id=i.GetProperty("id").GetString()!, Nombre=i.GetProperty("nombre").GetString()!, Email=i.GetProperty("email").GetString()! }).ToList();

        var rArt = await Api.GetArticulosAsync(disponible: true, skip: 0, limit: 500);
        if (rArt.HasValue) articulosList = rArt.Value.GetProperty("items").EnumerateArray()
            .Select(i => new DtoSelect { Id=i.GetProperty("id").GetString()!, Nombre=i.GetProperty("nombre").GetString()!, Precio=i.GetProperty("precio").GetDouble() }).ToList();
    }

    private async Task CargarAsync()
    {
        cargando=true;
        var r = await Api.GetPedidosAsync(restauranteId:string.IsNullOrEmpty(restFiltro)?null:restFiltro, estado:string.IsNullOrEmpty(estadoFiltro)?null:estadoFiltro, skip:pagina*limite, limit:limite);
        if (r.HasValue)
        {
            total = r.Value.GetProperty("total").GetInt32();
            pedidos = r.Value.GetProperty("items").EnumerateArray().Select(i => {
                var usuario = i.TryGetProperty("usuario", out var u) ? u : default;
                var restaurante = i.TryGetProperty("restaurante", out var rest) ? rest : default;
                return new PedidoVm
                {
                    Id = i.TryGetProperty("_id", out var id) ? id.GetString() : (i.TryGetProperty("id", out var id2) ? id2.GetString() : null),
                    UsuarioNombre = usuario.ValueKind != System.Text.Json.JsonValueKind.Undefined && usuario.TryGetProperty("nombre", out var un) ? un.GetString()! : "Desconocido",
                    UsuarioEmail = usuario.ValueKind != System.Text.Json.JsonValueKind.Undefined && usuario.TryGetProperty("email", out var ue) ? ue.GetString()! : "",
                    RestauranteNombre = restaurante.ValueKind != System.Text.Json.JsonValueKind.Undefined && restaurante.TryGetProperty("nombre", out var rn) ? rn.GetString()! : "Desconocido",
                    Total = i.TryGetProperty("totalPagar", out var t) ? t.GetDouble() : 0,
                    Estado = i.TryGetProperty("estado", out var e) ? e.GetString()! : "",
                    Fecha = i.TryGetProperty("fechaCreacion", out var f) ? f.GetDateTime().ToLocalTime() : DateTime.MinValue
                };
            }).ToList();
        }
        cargando=false;
    }

    private async Task Buscar() { pagina=0; await CargarAsync(); }
    private async Task CambiarPagina(int p) { pagina=p; await CargarAsync(); }

    private async Task Cancelar(string id)
    {
        var(ok,msg) = await Api.CancelarPedidoAsync(id);
        msgGlobal = ok ? "Pedido cancelado y stock restaurado." : $"Error: {msg}"; isErr=!ok;
        if(ok) await CargarAsync();
    }

    private async Task CrearPedido()
    {
        if (!pItems.Any()||string.IsNullOrEmpty(pUsuId)||string.IsNullOrEmpty(pRestId))
        { msgModal="Completa todos los campos."; modalErr=true; return; }
        guardando=true; msgModal="";
        var payload = new {
            usuarioId=pUsuId, restauranteId=pRestId,
            items=pItems.Where(i=>!string.IsNullOrEmpty(i.ArticuloId)).Select(i=>new{articuloId=i.ArticuloId,cantidad=i.Cantidad}).ToArray(),
            ubicacionEntrega=new{type="Point",coordinates=new[]{pLon,pLat}}
        };
        var (ok, msg) = await Api.CrearPedidoAsync(payload);
        if (ok) { crearModal=false; msgGlobal="Pedido creado con transaccion ACID exitosa."; isErr=false; pItems=new(){new()}; await CargarAsync(); }
        else { msgModal=$"Error: {msg}"; modalErr=true; }
        guardando=false;
    }

    private static string GetEstadoBadge(string estado) => estado switch {
        "RECIBIDO" => "badge-warning",
        "PREPARANDO" => "badge-info",
        "EN_CAMINO" => "badge-info",
        "ENTREGADO" => "badge-success",
        "CANCELADO" => "badge-danger",
        _ => "badge-muted"
    };
}
